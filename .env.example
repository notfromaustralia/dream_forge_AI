# DreamForge Environment Variables

# AI mode: demo | live (canned responses vs GitHub Models)
DREAMFORGE_MODE=demo

# Auth mode: demo | azure (demo = local/MCP bypass; azure = JWT required)
DREAMFORGE_AUTH_MODE=demo

# Database
# Local Homebrew Postgres (default): postgresql+asyncpg://YOUR_USER@localhost:5432/dreamforge
# Docker Compose: postgresql+asyncpg://dreamforge:dreamforge@localhost:5432/dreamforge
DATABASE_URL=postgresql+asyncpg://sydney@localhost:5432/dreamforge

# API URLs (local)
DREAMFORGE_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_DREAMFORGE_AUTH_MODE=demo

# Production split deploy (Vercel frontend + Render backend)
# Vercel env:  NEXT_PUBLIC_API_URL=https://dreamforge-api.onrender.com/api/v1
# Render env:  CORS_ORIGINS=https://your-app.vercel.app
# Render auto-sets DATABASE_URL from Postgres; postgresql:// is normalized to postgresql+asyncpg://

# Azure Entra ID (for live auth)
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# AI Models (optional — live mode)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://models.inference.ai.azure.com
AI_MODEL=gpt-4o-mini
GITHUB_TOKEN=

# MCP Server
DREAMFORGE_UNIVERSE_ID=
